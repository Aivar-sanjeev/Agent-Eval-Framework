# Groq — https://console.groq.com/keys (OpenAI-compatible API)
GROQ_API_KEY=

# Optional
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_AGENT_MODEL=llama-3.3-70b-versatile
# GROQ_JUDGE_MODEL=llama-3.3-70b-versatile
# Faster/cheaper judge: GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# Rate limiting — applies to agent + judge calls
# GROQ_REQUEST_DELAY_MS=80
# GROQ_MAX_RETRIES=10
# GROQ_RETRY_BASE_SEC=2.0
